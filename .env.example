# Database Configuration
DATABASE_URL=mysql+pymysql://username:password@host:3306/database_name

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,csv,txt,jpg,jpeg,png,gif

# Security Configuration
SENSITIVE_COLUMNS=aadhar_no,aadhar_number,pan_no,pan_number,phone,email,address,ssn,passport_no
BLOCKED_QUERIES=password,secret,confidential,private

# Chat Configuration
MAX_CHAT_HISTORY=50
RESPONSE_TIMEOUT=30
